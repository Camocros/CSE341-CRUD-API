{
  "swagger": "2.0",
  "info": {
    "version": "1.0.0",
    "title": "W04 CRUD API with OAuth",
    "description": "API for Cases and Materials with GitHub OAuth Authentication"
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http",
    "https"
  ],
  "securityDefinitions": {
    "oauth2": {
      "type": "oauth2",
      "authorizationUrl": "https://github.com/login/oauth/authorize",
      "flow": "implicit",
      "scopes": {
        "user:email": "Read user email"
      }
    }
  },
  "paths": {
    "/auth/login": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Login with GitHub OAuth",
        "description": "Redirects to GitHub OAuth login page",
        "responses": {
          "302": {
            "description": "Redirect to GitHub OAuth"
          }
        }
      }
    },
    "/auth/callback": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "GitHub OAuth Callback",
        "description": "Callback URL for GitHub OAuth (handled automatically by GitHub)",
        "responses": {
          "302": {
            "description": "Redirect to profile after successful authentication"
          }
        }
      }
    },
    "/auth/profile": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Get current user profile",
        "description": "Returns the authenticated user's profile information",
        "responses": {
          "200": {
            "description": "User profile retrieved successfully"
          },
          "401": {
            "description": "User not authenticated"
          }
        }
      }
    },
    "/auth/logout": {
      "get": {
        "tags": [
          "Authentication"
        ],
        "summary": "Logout",
        "description": "Destroys the user session and logs out",
        "responses": {
          "200": {
            "description": "Logged out successfully"
          }
        }
      }
    },
    "/cases": {
      "get": {
        "tags": [
          "Cases"
        ],
        "summary": "Get all cases",
        "description": "Public endpoint - no authentication required",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      },
      "post": {
        "tags": [
          "Cases"
        ],
        "summary": "Create a new case",
        "description": "Requires GitHub OAuth authentication",
        "security": [
          {
            "oauth2": ["user:email"]
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Case object that needs to be added",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Case"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Case created"
          },
          "400": {
            "description": "Invalid input"
          },
          "401": {
            "description": "Unauthorized - authentication required"
          }
        }
      }
    },
    "/cases/{id}": {
      "get": {
        "tags": [
          "Cases"
        ],
        "summary": "Get a case by ID",
        "description": "Public endpoint - no authentication required",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of case to return",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "404": {
            "description": "Case not found"
          }
        }
      },
      "put": {
        "tags": [
          "Cases"
        ],
        "summary": "Update an existing case",
        "description": "Requires GitHub OAuth authentication",
        "security": [
          {
            "oauth2": ["user:email"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of case to update",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Case object that needs to be updated",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Case"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful operation"
          },
          "400": {
            "description": "Invalid input"
          },
          "401": {
            "description": "Unauthorized - authentication required"
          },
          "404": {
            "description": "Case not found"
          }
        }
      },
      "delete": {
        "tags": [
          "Cases"
        ],
        "summary": "Delete a case",
        "description": "Requires GitHub OAuth authentication",
        "security": [
          {
            "oauth2": ["user:email"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Case ID to delete",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Unauthorized - authentication required"
          },
          "404": {
            "description": "Case not found"
          }
        }
      }
    },
    "/materials": {
      "get": {
        "tags": [
          "Materials"
        ],
        "summary": "Get all materials",
        "description": "Public endpoint - no authentication required",
        "responses": {
          "200": {
            "description": "Successful operation"
          }
        }
      },
      "post": {
        "tags": [
          "Materials"
        ],
        "summary": "Create a new material",
        "description": "Requires GitHub OAuth authentication",
        "security": [
          {
            "oauth2": ["user:email"]
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Material object that needs to be added",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Material"
            }
          }
        ],
        "responses": {
          "201": {
            "description": "Material created"
          },
          "400": {
            "description": "Invalid input"
          },
          "401": {
            "description": "Unauthorized - authentication required"
          }
        }
      }
    },
    "/materials/{id}": {
      "get": {
        "tags": [
          "Materials"
        ],
        "summary": "Get a material by ID",
        "description": "Public endpoint - no authentication required",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of material to return",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful operation"
          },
          "404": {
            "description": "Material not found"
          }
        }
      },
      "put": {
        "tags": [
          "Materials"
        ],
        "summary": "Update an existing material",
        "description": "Requires GitHub OAuth authentication",
        "security": [
          {
            "oauth2": ["user:email"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of material to update",
            "required": true,
            "type": "string"
          },
          {
            "in": "body",
            "name": "body",
            "description": "Material object that needs to be updated",
            "required": true,
            "schema": {
              "$ref": "#/definitions/Material"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful operation"
          },
          "400": {
            "description": "Invalid input"
          },
          "401": {
            "description": "Unauthorized - authentication required"
          },
          "404": {
            "description": "Material not found"
          }
        }
      },
      "delete": {
        "tags": [
          "Materials"
        ],
        "summary": "Delete a material",
        "description": "Requires GitHub OAuth authentication",
        "security": [
          {
            "oauth2": ["user:email"]
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "Material ID to delete",
            "required": true,
            "type": "string"
          }
        ],
        "responses": {
          "204": {
            "description": "Successful operation"
          },
          "401": {
            "description": "Unauthorized - authentication required"
          },
          "404": {
            "description": "Material not found"
          }
        }
      }
    }
  },
  "definitions": {
    "Case": {
      "type": "object",
      "required": ["caseNumber", "title", "description", "dateOpened", "status", "assignedTo", "priority"],
      "properties": {
        "caseNumber": {
          "type": "string",
          "description": "Unique case number"
        },
        "title": {
          "type": "string",
          "description": "Case title"
        },
        "description": {
          "type": "string",
          "description": "Detailed case description"
        },
        "dateOpened": {
          "type": "string",
          "description": "Date case was opened"
        },
        "status": {
          "type": "string",
          "enum": ["open", "in_progress", "closed"],
          "description": "Current case status"
        },
        "assignedTo": {
          "type": "string",
          "description": "Person assigned to case"
        },
        "priority": {
          "type": "string",
          "enum": ["low", "medium", "high"],
          "description": "Case priority level"
        }
      }
    },
    "Material": {
      "type": "object",
      "required": ["name", "type", "quantity", "unit"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Material name"
        },
        "type": {
          "type": "string",
          "description": "Material type/category"
        },
        "quantity": {
          "type": "number",
          "description": "Quantity available"
        },
        "unit": {
          "type": "string",
          "description": "Unit of measurement (kg, lbs, pieces, etc.)"
        }
      }
    }
  }
}
